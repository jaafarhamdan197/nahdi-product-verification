# Channable feed URLs (private — these export links grant access to the full
# product catalog, so keep the real values only in .env.local / Vercel, never
# committed). Get them from Channable: Projects > Exports > the JSON export
# link for each feed.
FEED_URL_AR=https://files.channable.com/REPLACE_AR.json
FEED_URL_EN=https://files.channable.com/REPLACE_EN.json
FEED_URL_UAE=https://files.channable.com/REPLACE_UAE.json

# NextAuth / Auth.js
# Generate with: npx auth secret
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (from Google Cloud Console > APIs & Services > Credentials)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Optional: how long (seconds) to keep a fetched feed in memory before
# re-downloading. Speeds up repeated searches and the search->export flow.
# Default 600 (10 min). Set to 0 to always fetch fresh.
FEED_CACHE_TTL_SECONDS=600

# Local testing only: set to "true" to bypass Google sign-in before OAuth
# credentials are configured. Hard-disabled in production (requires
# NODE_ENV != production), so it is safe to leave in .env.local. Never set
# this in a deployed environment.
DEV_AUTH_BYPASS=false

# Optional: comma-separated allowlist of emails permitted to sign in.
# Leave empty to allow any Google account that successfully authenticates
# (Google's OAuth consent screen "Testing" mode already restricts sign-in
# to the test users you add in Cloud Console).
ALLOWED_EMAILS=
